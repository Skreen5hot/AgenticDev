{
  "@context": "https://fnsr.example/context.jsonld",
  "@id": "urn:fnsr:run:kickoff",
  "tasks": [
    {
      "@id": "urn:fnsr:task:001-roadmap-draft",
      "agent": "planner",
      "status": "ready",
      "inputs": {
        "mode": "roadmap",
        "spec_path": "project/SPEC.md",
        "output_path": "project/ROADMAP.md"
      },
      "outputs": null,
      "depends_on": [],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:002-roadmap-repair",
      "agent": "mojibake-repair",
      "status": "ready",
      "inputs": {
        "source_task": "urn:fnsr:task:001-roadmap-draft"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:001-roadmap-draft"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:003-roadmap-apply",
      "agent": "applier",
      "status": "ready",
      "inputs": {
        "source_task": "urn:fnsr:task:002-roadmap-repair",
        "apply_root": "."
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:002-roadmap-repair"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:004-roadmap-review",
      "agent": "spec-reviewer",
      "status": "ready",
      "inputs": {
        "artifact": "Project Roadmap",
        "artifact_path": "project/ROADMAP.md",
        "focus": "completeness vs SPEC, phase ordering, scope-boundary clarity, missing concerns, ambiguous deferred decisions"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:003-roadmap-apply"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:005-roadmap-critique",
      "agent": "adversarial-critic",
      "status": "ready",
      "inputs": {
        "target": "urn:fnsr:task:004-roadmap-review",
        "mode": "find structural weaknesses in the roadmap, missed risks, mis-ordered phases, or aspirational acceptance language"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:004-roadmap-review"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:006-roadmap-synthesize",
      "agent": "synthesist",
      "status": "ready",
      "inputs": {
        "sources": [
          "urn:fnsr:task:004-roadmap-review",
          "urn:fnsr:task:005-roadmap-critique"
        ]
      },
      "outputs": null,
      "depends_on": [
        "urn:fnsr:task:004-roadmap-review",
        "urn:fnsr:task:005-roadmap-critique"
      ],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:007-roadmap-revise",
      "agent": "developer",
      "status": "ready",
      "inputs": {
        "instruction": "Revise project/ROADMAP.md to address the synthesist's findings. Produce minimal targeted changes; preserve phases not flagged for revision.",
        "target_file": "project/ROADMAP.md",
        "synthesist_task": "urn:fnsr:task:006-roadmap-synthesize"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:006-roadmap-synthesize"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:008-roadmap-revise-repair",
      "agent": "mojibake-repair",
      "status": "ready",
      "inputs": {
        "source_task": "urn:fnsr:task:007-roadmap-revise"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:007-roadmap-revise"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:009-roadmap-revise-apply",
      "agent": "applier",
      "status": "ready",
      "inputs": {
        "source_task": "urn:fnsr:task:008-roadmap-revise-repair",
        "apply_root": "."
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:008-roadmap-revise-repair"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:010-implementation-plan-draft",
      "agent": "planner",
      "status": "ready",
      "inputs": {
        "mode": "implementation-plan",
        "spec_path": "project/SPEC.md",
        "roadmap_path": "project/ROADMAP.md",
        "output_path": "project/IMPLEMENTATION_PLAN.md"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:009-roadmap-revise-apply"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:011-implementation-plan-repair",
      "agent": "mojibake-repair",
      "status": "ready",
      "inputs": {
        "source_task": "urn:fnsr:task:010-implementation-plan-draft"
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:010-implementation-plan-draft"],
      "attempts": 0,
      "history": []
    },
    {
      "@id": "urn:fnsr:task:012-implementation-plan-apply",
      "agent": "applier",
      "status": "ready",
      "inputs": {
        "source_task": "urn:fnsr:task:011-implementation-plan-repair",
        "apply_root": "."
      },
      "outputs": null,
      "depends_on": ["urn:fnsr:task:011-implementation-plan-repair"],
      "attempts": 0,
      "history": []
    }
  ]
}
